{
  "name": "claude-code-usage-community",
  "displayName": "Claude Code Usage (Community)",
  "description": "Monitor Claude Code usage and costs in VSCode status bar (community-maintained fork)",
  "version": "2.1.1",
  "publisher": "huanglune",
  "author": "huangliang",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/huanglune/ClaudeCodeUsage.git"
  },
  "bugs": {
    "url": "https://github.com/huanglune/ClaudeCodeUsage/issues"
  },
  "homepage": "https://github.com/huanglune/ClaudeCodeUsage",
  "keywords": [
    "claude",
    "claude-code",
    "usage",
    "cost",
    "monitoring",
    "ai",
    "anthropic",
    "token",
    "status-bar"
  ],
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "icon": "icon.png",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Claude Code Usage",
      "properties": {
        "claudeCodeUsage.refreshInterval": {
          "type": "number",
          "default": 60,
          "minimum": 30,
          "description": "Refresh interval in seconds (minimum 30 seconds)"
        },
        "claudeCodeUsage.dataDirectory": {
          "type": "string",
          "default": "",
          "description": "Custom Claude data directory path (leave empty for auto-detection)"
        },
        "claudeCodeUsage.language": {
          "type": "string",
          "enum": [
            "auto",
            "en",
            "de-DE",
            "zh-TW",
            "zh-CN",
            "ja",
            "ko"
          ],
          "default": "auto",
          "description": "Display language (auto-detection or manual selection)"
        },
        "claudeCodeUsage.decimalPlaces": {
          "type": "number",
          "default": 2,
          "minimum": 0,
          "maximum": 4,
          "description": "Number of decimal places for cost display"
        },
        "claudeCodeUsage.timezone": {
          "type": "string",
          "enum": [
            "auto",
            "UTC",
            "Asia/Shanghai",
            "Asia/Hong_Kong",
            "Asia/Tokyo",
            "Asia/Seoul",
            "Asia/Singapore",
            "Europe/London",
            "Europe/Berlin",
            "America/New_York",
            "America/Los_Angeles"
          ],
          "enumDescriptions": [
            "Follow the operating system timezone",
            "Coordinated Universal Time",
            "China Standard Time (UTC+8)",
            "Hong Kong Time (UTC+8)",
            "Japan Standard Time (UTC+9)",
            "Korea Standard Time (UTC+9)",
            "Singapore Time (UTC+8)",
            "UK (UTC or UTC+1)",
            "Central Europe (UTC+1 or UTC+2)",
            "US Eastern (UTC-5 or UTC-4)",
            "US Pacific (UTC-8 or UTC-7)"
          ],
          "default": "auto",
          "description": "Timezone used to bucket daily/hourly usage and determine 'today'. Changing this rebuilds the cache on next refresh."
        },
        "claudeCodeUsage.pricingOfflineMode": {
          "type": "boolean",
          "default": false,
          "description": "If true, do not fetch the latest Claude model pricing from LiteLLM at startup. Only use the snapshot bundled with the extension."
        },
        "claudeCodeUsage.codex.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable Codex usage scanning and UI rendering."
        },
        "claudeCodeUsage.codex.includeArchived": {
          "type": "boolean",
          "default": false,
          "description": "Include <codex-home>/archived_sessions/**/*.jsonl when loading Codex records."
        },
        "claudeCodeUsage.codex.dataDirectory": {
          "type": "string",
          "default": "",
          "description": "Custom Codex data directory path (overrides CODEX_HOME and ~/.codex)."
        }
      }
    },
    "commands": [
      {
        "command": "claudeCodeUsage.refresh",
        "title": "Refresh Usage Data",
        "category": "Claude Code Usage"
      },
      {
        "command": "claudeCodeUsage.showDetails",
        "title": "Show Usage Details",
        "category": "Claude Code Usage"
      },
      {
        "command": "claudeCodeUsage.openSettings",
        "title": "Open Settings",
        "category": "Claude Code Usage"
      },
      {
        "command": "claudeCodeUsage.showLogs",
        "title": "Show Logs",
        "category": "Claude Code Usage"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "rm -rf out && tsc -p ./ && node scripts/post-compile.mjs",
    "watch": "tsc -watch -p ./",
    "test": "node --import tsx --test scripts/update-pricing.test.ts src/pricing.test.ts src/codexDataLoader.test.ts",
    "update-pricing": "tsx scripts/update-pricing.ts"
  },
  "devDependencies": {
    "@types/glob": "^9.0.0",
    "@types/node": "24.0.15",
    "@types/vscode": "^1.74.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "undici": "^6.25.0"
  }
}
